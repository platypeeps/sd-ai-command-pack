{
  "schemaVersion": 2,
  "description": "Known sd-ai-command-pack consumer repositories for operator-triggered fleet refreshes.",
  "consumers": [
    {
      "name": "rwbp-coordinator",
      "github": "platypeeps/rwbp-coordinator",
      "pathHint": "~/repos/rwbp/rwbp-coordinator",
      "platforms": ["claude", "gemini", "github", "opencode"],
      "rolloutPriority": 10,
      "candidateTimeoutSeconds": 180,
      "candidateChecks": [["node", "scripts/check-review-churn.mjs"]]
    },
    {
      "name": "loadsmith",
      "github": "platypeeps/loadsmith",
      "pathHint": "~/repos/platypeeps/loadsmith",
      "platforms": ["claude", "gemini", "github", "opencode"],
      "rolloutPriority": 20,
      "candidateTimeoutSeconds": 180,
      "candidateChecks": [["bash", "scripts/check_review_readiness.sh", "--all", "--skip-build"]]
    },
    {
      "name": "hoa-manager",
      "github": "platypeeps/hoa-manager",
      "pathHint": "~/repos/platypeeps/hoa-manager",
      "platforms": ["claude", "gemini", "github", "opencode"],
      "rolloutPriority": 30,
      "candidateTimeoutSeconds": 180,
      "candidateChecks": [
        ["bash", "scripts/update_repomix"],
        ["node", "scripts/check-review-preflight.mjs"]
      ]
    },
    {
      "name": "rwbp-website",
      "github": "platypeeps/rwbp-website",
      "pathHint": "~/repos/rwbp/rwbp-website",
      "platforms": ["claude", "gemini", "github", "opencode"],
      "rolloutPriority": 40,
      "candidateTimeoutSeconds": 300,
      "candidateChecks": [
        ["node", "scripts/sd-ai-command-pack-review-preflight.mjs"],
        ["node", "scripts/ops-check.mjs"]
      ]
    },
    {
      "name": "mezmo_benchmark",
      "github": "answerbook/mezmo_benchmark",
      "pathHint": "~/repos/mezmo/mezmo_benchmark",
      "platforms": ["claude", "gemini", "github", "opencode"],
      "rolloutPriority": 50,
      "candidateTimeoutSeconds": 300,
      "candidateChecks": [["python3", "scripts/check-review-cycle-patterns.py", "--base", "HEAD", "--include-working-tree"]]
    },
    {
      "name": "se-ai-command-pack",
      "github": "platypeeps/se-ai-command-pack",
      "pathHint": "~/repos/platypeeps/se-ai-command-pack",
      "platforms": ["claude", "gemini", "github", "opencode"],
      "rolloutPriority": 60,
      "candidateTimeoutSeconds": 180,
      "candidateChecks": [["bash", "scripts/sd-ai-command-pack-housekeeping.sh", "--self-test"]]
    },
    {
      "name": "anomaly-metric-creator",
      "github": "platypeeps/anomaly-metric-creator",
      "pathHint": "~/repos/platypeeps/anomaly-metric-creator",
      "platforms": ["claude", "gemini", "github", "opencode"],
      "rolloutPriority": 90,
      "candidateTimeoutSeconds": 300,
      "candidateChecks": [
        ["python3", "tools/check_ci_review_contract.py"],
        ["python3", "tools/check_copilot_instruction_contract.py"]
      ]
    }
  ],
  "excludedAliases": [
    {
      "name": "green-button-manager",
      "reason": "stale local clone alias for loadsmith"
    },
    {
      "name": "trellis-review-pr-pack",
      "reason": "historical predecessor; this repository is the canonical pack"
    }
  ]
}
