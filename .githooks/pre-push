#!/usr/bin/env bash
# Chore-scope guard: direct pushes to main may only touch Trellis chore
# paths (.trellis/tasks/**, .trellis/workspace/**). Everything else goes
# through a pull request, matching the repository's branch-protection
# policy (admin pushes bypass GitHub's PR requirement, so this hook is
# the guardrail that keeps the bypass honest).
#
# Install once per clone:  git config core.hooksPath .githooks
# One-shot emergency bypass:
#   SD_AI_COMMAND_PACK_CHORE_SCOPE_BYPASS=1 git push ...
set -uo pipefail

if [ "${SD_AI_COMMAND_PACK_CHORE_SCOPE_BYPASS:-0}" = "1" ]; then
    echo "pre-push: chore-scope guard bypassed via SD_AI_COMMAND_PACK_CHORE_SCOPE_BYPASS" >&2
    exit 0
fi

zero=0000000000000000000000000000000000000000
status=0

while read -r _local_ref local_sha remote_ref remote_sha; do
    [ "$remote_ref" = "refs/heads/main" ] || continue
    # Branch deletion is governed by the remote ruleset, not this hook.
    [ "$local_sha" != "$zero" ] || continue
    if [ "$remote_sha" = "$zero" ]; then
        # Fail closed: creating remote main directly has no chore baseline
        # to diff against, so it is never chore scope.
        echo "pre-push: creating remote main directly is outside chore scope; bypass explicitly if intentional" >&2
        status=1
        continue
    fi
    if ! git rev-parse -q --verify "$remote_sha^{commit}" >/dev/null 2>&1; then
        echo "pre-push: remote main head $remote_sha is unknown locally; fetch before pushing" >&2
        status=1
        continue
    fi
    if ! changed=$(git diff --name-only "$remote_sha" "$local_sha" --); then
        # Fail closed rather than masking a diff error as "no offenders".
        echo "pre-push: could not diff $remote_sha..$local_sha; failing closed" >&2
        status=1
        continue
    fi
    [ -n "$changed" ] || continue
    offenders=$(printf '%s\n' "$changed" | grep -Ev '^\.trellis/(tasks|workspace)/')
    grep_rc=$?
    if [ "$grep_rc" -ge 2 ]; then
        echo "pre-push: chore-scope filter failed (grep exit $grep_rc); failing closed" >&2
        status=1
        continue
    fi
    if [ -n "$offenders" ]; then
        {
            echo "pre-push: direct pushes to main are Trellis chore-scope only"
            echo "pre-push: (.trellis/tasks/**, .trellis/workspace/**). Blocked paths:"
            echo "$offenders" | head -10 | sed 's/^/  - /'
            echo "pre-push: open a pull request instead, or bypass once with"
            echo "pre-push:   SD_AI_COMMAND_PACK_CHORE_SCOPE_BYPASS=1 git push ..."
        } >&2
        status=1
    fi
done

exit "$status"
