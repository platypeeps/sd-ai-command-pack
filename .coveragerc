[run]
# Keep the 100% line-and-branch gate focused on the installer. Helper scripts are covered
# by focused unit/subprocess tests and syntax checks, but many branches
# intentionally depend on optional local CLIs such as Prism, Gito, GitHub, and
# Trellis and are not part of this strict installer coverage metric.
include =
    install.py
    installer/*
    scripts/sd-ai-command-pack-*.py
    */scripts/sd-ai-command-pack-*.py
parallel = True
branch = True

[paths]
# The symlink-execution test runs the entry through a temp-dir symlink;
# map that recorded path back onto the real entry file.
entry =
    install.py
    */install.py
# Shipped helper scripts execute as installed copies inside temp consumer
# repos (and as templates/scripts twins); map every copy back onto the
# canonical scripts/ source. Twins are byte-identical so line numbers align.
helper_scripts =
    scripts/
    */scripts/

[report]
show_missing = True
fail_under = 100
